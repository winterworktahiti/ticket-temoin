{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ticket-temoin",
  "main": "worker.js",
  "compatibility_date": "2026-07-08",
  "vars": {
    "QWEN_BASE_URL": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
  },
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "STATS_KV",
      "id": "ae6ae083ae5a4927bfb89ae74353a52d"
    }
  ],
  "d1_databases": [
    {
      "binding": "PRICES_DB",
      "database_name": "fenua-check-prices",
      "database_id": "d77ed0b1-cec6-4600-9bfd-5bdc47071c5b"
    }
  ],
  "ratelimits": [
    {
      "name": "API_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 20, "period": 60 }
    }
  ]
}
